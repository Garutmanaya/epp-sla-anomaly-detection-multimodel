{
  "active_version": "v1",

  "paths": {
    "model": "models/v1/model_bundle.pkl",
    "thresholds": "configs/v1/threshold-config.json",
    "data_config": "configs/v1/data-config.json"
  },

  "data": {
    "filename": "synthetic_epp_logs.csv"
  },
  "s3": 
  {
    "enabled": false,
    "bucket": "epp-sla",
    "prefix": "anomaly-detection",
    "region": "us-east-1"
  },
  "flags": {
    "upload_to_s3": false,
    "download_from_s3": false
  },
  "api": {
    "base_url": "http://localhost:8000",
    "health_path": "/",
    "predict_path": "/predict",
    "compare_path": "/compare"
  },
  "sagemaker": {
    "enabled": false,
    "endpoint_name": "epp-sla-hourly-anomaly-endpoint",
    "region": "us-east-1"
  }
}

